# BikeVault Environment Configuration
# Copy this file to .env and update with your actual values

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your_secret_key_here

# Database Configuration (for Production/Server)
# Change FLASK_ENV to 'production' and fill these values
MYSQL_USER=bikevault_user
MYSQL_PASSWORD=your_secure_password
MYSQL_HOST=192.168.x.x
MYSQL_PORT=3306
MYSQL_DB=bikevault_db

# Example for Bosch Internal Server:
# MYSQL_HOST=bosch-db-server.local
# MYSQL_PORT=3306
# MYSQL_USER=it_provided_username
# MYSQL_PASSWORD=it_provided_password
# MYSQL_DB=bikevault_production
